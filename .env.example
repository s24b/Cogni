# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL — used for OAuth redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google Calendar OAuth (optional — only needed if enabling calendar integration)
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret

# Dev only — enables mock mode for all agents (never set this in Vercel)
# NEXT_PUBLIC_MOCK_AGENTS=true
